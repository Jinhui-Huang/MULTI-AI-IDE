{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/ide"],
      "outFiles": ["${workspaceFolder}/ide/dist/**/*.js"],
      "preLaunchTask": "build-extension"
    },
    {
      "name": "Extension (Dev with WebView HMR)",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/ide"],
      "outFiles": ["${workspaceFolder}/ide/dist/**/*.js"],
      "env": {
        "VITE_DEV": "true"
      },
      "preLaunchTask": "dev-extension-with-hmr"
    }
  ]
}