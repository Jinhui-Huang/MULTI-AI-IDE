TELEGRAM_BOT_TOKEN=12345678:APP_TOKEN
ALLOWED_CHAT_IDS=12345678
DEFAULT_CWD=d:/ai-agent-ide/multi-ai-ide

# Uses the Codex CLI already installed/configured on this machine.
CODEX_BIN=codex
DEFAULT_MODEL=gpt-5.4
AVAILABLE_MODELS=gpt-5.4,gpt-5.4-mini,gpt-5.3-codex

# Default mode: low-friction sandboxed execution in the configured workspace.
# Set CODEX_DANGEROUS_BYPASS=true only for a trusted bot if Codex must run
# commands that the Windows sandbox blocks, such as Git for Windows/MSYS SSH.
CODEX_FULL_AUTO=true
CODEX_SANDBOX=workspace-write
CODEX_DANGEROUS_BYPASS=false
CODEX_SKIP_GIT_REPO_CHECK=false
